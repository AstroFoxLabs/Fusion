{
    "compilerOptions": {
        "baseUrl": ".",
        "moduleResolution": "bundler",
        "target": "ES2022",
        "module": "ESNext",
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@shared/*": ["../shared/*"],
            "@render/*": ["./*"]
        }
    },
    "include": ["./**/*.ts", "./**/*.vue"]
}
